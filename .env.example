# Copy this file to .env in a target project or export these variables in your shell.
# Never commit real secrets.

# Notion
NOTION_TOKEN=
NOTION_PROJECTS_DB_ID=
NOTION_RECORDS_DB_ID=
NOTION_VERSION=2022-06-28

# Optional Notion property overrides
NOTION_PROJECT_TITLE_PROP=Project Name
NOTION_RECORD_TITLE_PROP=Title
NOTION_PROJECT_ID_PROP=Project ID
NOTION_RECORD_TYPE_PROP=Record Type
NOTION_STATUS_PROP=Status
NOTION_IMPORTANCE_PROP=Importance
NOTION_LOCAL_PATH_PROP=Local Path
NOTION_SOURCE_HASH_PROP=Source Hash
NOTION_SUMMARY_PROP=Summary
NOTION_TAGS_PROP=Tags
NOTION_DATE_PROP=Date
NOTION_AREA_PROP=Area

# Feishu / Lark
FEISHU_BASE_URL=https://open.feishu.cn
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_BITABLE_APP_TOKEN=
FEISHU_BITABLE_TABLE_ID=

# Feishu document import. Required only when using sync_feishu.py --sync-docs --apply.
FEISHU_FOLDER_TOKEN=
FEISHU_DOC_URL_BASE=https://feishu.cn/docx

# Optional Feishu endpoint overrides.
FEISHU_UPLOAD_ENDPOINT=
FEISHU_IMPORT_ENDPOINT=
FEISHU_UPLOAD_PARENT_TYPE=explorer
FEISHU_IMPORT_TYPE=docx
FEISHU_IMPORT_MOUNT_TYPE=1
